{
  "version": 2,
  "builds": [
    {
      "src": "app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "app.js"
    },
    {
      "src": "/upload-financiero",
      "dest": "app.js"
    },
    {
      "src": "/financiero/(.*)",
      "dest": "/financiero-app/browser/$1"
    },
    {
      "src": "/financiero",
      "dest": "/financiero-app/browser/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
